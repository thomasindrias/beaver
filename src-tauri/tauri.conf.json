{
  "productName": "Osprey",
  "version": "0.1.0",
  "identifier": "se.djtl.osprey",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    },
    "externalBin": ["binaries/ollama"]
  },
  "plugins": {
    "sql": {},
    "clipboard-manager": {},
    "global-shortcut": {},
    "shell": { "open": true },
    "notification": {}
  }
}
