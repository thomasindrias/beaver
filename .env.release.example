# Copy to .env.release (gitignored) and fill in to produce a signed, notarized DMG.
# Leave this file blank/unset to build an UNSIGNED DMG for local testing.

# Developer ID Application identity, exactly as shown by:
#   security find-identity -v -p codesigning
# Quote it - the value contains spaces and parentheses.
# e.g. "Developer ID Application: Example Developer (TEAMID1234)"
APPLE_SIGNING_IDENTITY=

# --- Notarization: choose ONE method ---

# Method A — Apple ID + app-specific password (appleid.apple.com > App-Specific Passwords)
# APPLE_TEAM_ID is the team that owns the Developer ID cert.
APPLE_ID=
APPLE_PASSWORD=
APPLE_TEAM_ID=

# Method B — App Store Connect API key (.p8). Comment out Method A if you use this.
# APPLE_API_ISSUER=
# APPLE_API_KEY=
# APPLE_API_KEY_PATH=

# In-app updater signing (minisign key generated with `pnpm tauri signer generate`).
# Content of ~/.tauri/beaver-updater.key; password is empty for a passwordless key.
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
