{
  "name": "beaver",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thomasindrias/beaver.git"
  },
  "bugs": {
    "url": "https://github.com/thomasindrias/beaver/issues"
  },
  "homepage": "https://github.com/thomasindrias/beaver#readme",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:onboarding": "BEAVER_FORCE_ONBOARDING=1 tauri dev",
    "test": "vitest --exclude 'apps/**'",
    "test:run": "vitest run --exclude 'apps/**' --passWithNoTests",
    "release:mac": "bash scripts/release-macos.sh",
    "website:dev": "pnpm --filter @beaver/website dev",
    "website:build": "pnpm --filter @beaver/website build",
    "website:test": "pnpm --filter @beaver/website test:run",
    "website:typecheck": "pnpm --filter @beaver/website typecheck"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.9.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^4.1.7",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.8.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.7"
  }
}
